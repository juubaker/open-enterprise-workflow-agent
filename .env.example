# =====================================================================
# LLM provider — pick one: anthropic, openai, or ollama
# =====================================================================
LLM_PROVIDER=anthropic

# Optional: override the default model. Defaults are:
#   anthropic → claude-opus-4-7
#   openai    → gpt-4o-mini
#   ollama    → qwen2.5:7b
# AGENT_MODEL=claude-opus-4-7

# Provider credentials (only the one matching LLM_PROVIDER is required)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=
# OPENAI_BASE_URL=                                # for OpenAI-compatible providers like Together AI, Groq
OLLAMA_BASE_URL=http://localhost:11434/v1

# =====================================================================
# Agent budgets and behavior
# =====================================================================
AGENT_MAX_ITERATIONS=10
AGENT_MAX_COST_USD=1.00
AGENT_TRACE=0

# =====================================================================
# Audit log destination
# =====================================================================
AUDIT_PATH=./audit.log

# =====================================================================
# HTTP server
# =====================================================================
PORT=3000
